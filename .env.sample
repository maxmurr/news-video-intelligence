# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# Postgres (docker compose)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/news_intelligence

# RustFS / S3-compatible storage (docker compose)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET=uploads
S3_REGION=ap-southeast-1

# Sentry — DSN from project Settings → Client Keys; token from Auth Tokens
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build/CI only — uploads source maps. Never client-exposed.
SENTRY_AUTH_TOKEN=

# Langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=